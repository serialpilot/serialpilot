{
  "name": "serialpilot-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Node.js packages to access serial ports, process data from them and speak many protocols",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2",
  "license": "MIT",
  "scripts": {
    "build": "lerna run build",
    "format": "eslint --fix",
    "lint": "eslint",
    "outdated": "lerna exec --no-bail npm outdated && npm outdated",
    "publish": "changeset publish",
    "release": "changeset publish",
    "version": "changeset version",
    "changeset": "changeset",
    "test:arduino": "TEST_PORT=$(./bin/find-arduino.ts) npm test",
    "test:watch": "mocha -w",
    "test": "nyc --reporter lcov --reporter text mocha",
    "typecheck": "lerna exec tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riteshrana/serialpilot.git"
  },
  "homepage": "https://github.com/riteshrana/serialpilot#readme",
  "bugs": "https://github.com/riteshrana/serialpilot/issues",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/js": "9.39.2",
    "@stylistic/eslint-plugin": "5.6.1",
    "@tsconfig/node24": "24.0.3",
    "@types/chai": "5.2.3",
    "@types/debug": "4.1.12",
    "@types/mocha": "10.0.10",
    "@types/node": "25.0.3",
    "@types/sinon": "21.0.0",
    "chai": "6.2.2",
    "esbuild": "0.27.2",
    "esbuild-register": "3.6.0",
    "eslint": "9.39.2",
    "eslint-plugin-mocha": "11.2.0",
    "globals": "15.14.0",
    "lerna": "9.0.7",
    "lerna-changelog": "2.2.0",
    "mocha": "11.7.5",
    "nyc": "17.1.0",
    "sinon": "21.0.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.51.0"
  }
}
