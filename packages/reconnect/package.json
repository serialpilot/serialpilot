{
  "name": "@serialpilot/reconnect",
  "version": "1.0.0",
  "description": "Auto-reconnect wrapper for SerialPilot",
  "license": "MIT",
  "author": "Ritesh Rana <contact@riteshrana.engineer>",
  "homepage": "https://github.com/serialpilot/serialpilot/tree/main/packages/reconnect",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serialpilot/serialpilot.git",
    "directory": "packages/reconnect"
  },
  "bugs": "https://github.com/serialpilot/serialpilot/issues",
  "main": "./dist/index.js",
