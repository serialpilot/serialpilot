{
  "name": "@serialpilot/repl",
  "version": "1.0.1",
  "description": "A scriptable Node REPL bound to a serial port. Includes the `serialpilot-repl` CLI.",
  "license": "MIT",
  "author": "Ritesh Rana <contact@riteshrana.engineer>",
  "homepage": "https://github.com/serialpilot/serialpilot/tree/main/packages/repl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serialpilot/serialpilot.git",
    "directory": "packages/repl"
  },
  "bugs": "https://github.com/serialpilot/serialpilot/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "serialpilot",
    "repl",
    "cli",
    "interactive",
    "debug",
    "serial"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc --build tsconfig-build.json"
  },
  "dependencies": {
    "promirepl": "^2.0.1",
    "serialpilot": "1.0.1"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "serialpilot-repl": "./dist/index.js"
  }
}
