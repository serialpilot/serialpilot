{
  "name": "@serialpilot/bindings-cpp",
  "version": "1.0.1",
  "description": "SerialPilot hardware bindings for Node.js written in C++",
  "license": "MIT",
  "author": "Ritesh Rana <contact@riteshrana.engineer>",
  "homepage": "https://github.com/serialpilot/serialpilot/tree/main/packages/bindings-cpp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serialpilot/serialpilot.git",
    "directory": "packages/bindings-cpp"
  },
  "bugs": {
    "email": "contact@riteshrana.engineer"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/*.cpp",
    "src/*.h",
    "binding.gyp",
    "prebuilds"
  ],
  "keywords": [
    "serialpilot-binding",
    "binding",
    "napi",
    "native",
    "com",
    "com port",
    "hardware",
    "iot",
    "modem",
    "serial",
    "serial port",
    "tty",
    "uart"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": true,
  "scripts": {
    "build": "tsc --build tsconfig-build.json",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --target 20.0.0 --force --strip --verbose",
    "prebuildify-cross": "prebuildify-cross --napi --target 20.0.0 --force --strip --verbose",
    "rebuild": "node-gyp rebuild",
    "test": "nyc --reporter lcov --reporter text mocha",
    "test:arduino": "TEST_PORT=$(./bin/find-arduino.ts) npm test",
    "test:watch": "mocha -w",
    "semantic-release": "semantic-release",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@serialpilot/bindings-interface": "1.0.1",
    "@serialpilot/parser-readline": "1.0.1",
    "debug": "4.4.0",
    "node-addon-api": "8.3.0",
    "node-gyp-build": "4.8.4"
  },
  "devDependencies": {
    "@semantic-release/exec": "6.0.3",
    "@serialpilot/binding-mock": "1.0.1",
    "@types/chai": "5.0.1",
    "@types/chai-subset": "1.3.6",
    "@types/debug": "4.1.12",
    "@types/mocha": "10.0.10",
    "@types/node": "22.19.1",
    "cc": "3.0.1",
    "chai": "6.2.1",
    "chai-subset": "1.6.0",
    "esbuild": "0.27.1",
    "esbuild-register": "3.6.0",
    "mocha": "11.7.5",
    "node-abi": "3.71.0",
    "node-gyp": "11.0.0",
    "nyc": "17.1.0",
    "prebuildify": "6.0.1",
    "prebuildify-cross": "5.1.1",
    "semantic-release": "24.2.0",
    "shx": "0.3.4",
    "sinon": "21.0.0",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "mocha": {
    "bail": true,
    "require": [
      "esbuild-register"
    ],
    "spec": "lib/**/*.test.*"
  },
  "gypfile": true,
  "binary": {
    "napi_versions": [
      8
    ]
  },
  "cc": {
    "filter": [
      "legal/copyright",
      "build/include"
    ],
    "files": [
      "src/*.cpp",
      "src/*.h"
    ],
    "linelength": "120"
  }
}
