{
  "name": "@serialpilot/serialpilot",
  "version": "1.0.1",
  "description": "Scoped alias for the SerialPilot umbrella package — re-exports everything from `serialpilot`. Use whichever name fits your import style.",
  "license": "MIT",
  "homepage": "https://github.com/serialpilot/serialpilot/tree/main/packages/scoped-umbrella",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serialpilot/serialpilot.git",
    "directory": "packages/scoped-umbrella"
  },
  "bugs": "https://github.com/serialpilot/serialpilot/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "serial port",
    "serial",
    "serialpilot",
    "hardware",
    "iot",
    "robotics",
    "tty",
    "UART"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc --build tsconfig-build.json"
  },
  "dependencies": {
    "serialpilot": "1.0.1"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
