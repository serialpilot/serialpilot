---
import MarketingLayout from '~/layouts/MarketingLayout.astro';
import Oscilloscope from '~/components/Oscilloscope';
import ParserTicker from '~/components/ParserTicker.astro';
import CodeTabs from '~/components/CodeTabs.astro';
import PackageMatrix from '~/components/PackageMatrix.astro';
import WebSerialDemo from '~/components/WebSerialDemo';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const link = (p: string) => `${base}${p.replace(/^\//, '')}`;

const installRaw = `# Install the meta package — bindings, stream, parsers
$ npm install serialpilot

# Or pick what you need
$ npm install @serialpilot/bindings-cpp @serialpilot/stream
$ npm install @serialpilot/parser-readline`;

const installHtml = `<span class="c-c"># Install the meta package — bindings, stream, parsers</span>
<span class="c-p">$</span> npm install serialpilot

<span class="c-c"># Or pick what you need</span>
<span class="c-p">$</span> npm install @serialpilot/bindings-cpp @serialpilot/stream
<span class="c-p">$</span> npm install @serialpilot/parser-readline`;

const openRaw = `import { SerialPilot, ReadlineParser } from 'serialpilot'

const port = new SerialPilot({
  path: '/dev/tty.usbmodem1421',
  baudRate: 115200,
})

const lines = port.pipe(new ReadlineParser({ delimiter: '\\n' }))

lines.on('data', line => {
  console.log('<-', line)
})

port.write('PING\\n')`;

const openHtml = `<span class="c-k">import</span> { SerialPilot, ReadlineParser } <span class="c-k">from</span> <span class="c-s">'serialpilot'</span>

<span class="c-k">const</span> port = <span class="c-k">new</span> <span class="c-t">SerialPilot</span>({
  path: <span class="c-s">'/dev/tty.usbmodem1421'</span>,
  baudRate: <span class="c-n">115200</span>,
})

<span class="c-k">const</span> lines = port.<span class="c-f">pipe</span>(<span class="c-k">new</span> <span class="c-t">ReadlineParser</span>({ delimiter: <span class="c-s">'\\n'</span> }))

lines.<span class="c-f">on</span>(<span class="c-s">'data'</span>, line =&gt; {
  console.<span class="c-f">log</span>(<span class="c-s">'&lt;-'</span>, line)
})

port.<span class="c-f">write</span>(<span class="c-s">'PING\\n'</span>)`;

const mockRaw = `import { SerialPilotMock, ReadlineParser } from 'serialpilot'
import { MockBinding } from '@serialpilot/binding-mock'

MockBinding.createPort('/dev/ROBOT', { echo: true })

const port = new SerialPilotMock({ path: '/dev/ROBOT', baudRate: 9600 })
const lines = port.pipe(new ReadlineParser({ delimiter: '\\n' }))

port.write('hello\\n')
// lines emits 'hello' — no hardware required`;

const mockHtml = `<span class="c-k">import</span> { SerialPilotMock, ReadlineParser } <span class="c-k">from</span> <span class="c-s">'serialpilot'</span>
<span class="c-k">import</span> { MockBinding } <span class="c-k">from</span> <span class="c-s">'@serialpilot/binding-mock'</span>

MockBinding.<span class="c-f">createPort</span>(<span class="c-s">'/dev/ROBOT'</span>, { echo: <span class="c-n">true</span> })

<span class="c-k">const</span> port = <span class="c-k">new</span> <span class="c-t">SerialPilotMock</span>({ path: <span class="c-s">'/dev/ROBOT'</span>, baudRate: <span class="c-n">9600</span> })
<span class="c-k">const</span> lines = port.<span class="c-f">pipe</span>(<span class="c-k">new</span> <span class="c-t">ReadlineParser</span>({ delimiter: <span class="c-s">'\\n'</span> }))

port.<span class="c-f">write</span>(<span class="c-s">'hello\\n'</span>)
<span class="c-c">// lines emits 'hello' — no hardware required</span>`;
---
<MarketingLayout title="SerialPilot — Talk to hardware. From JavaScript.">

  <!-- HERO ─────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__canvas">
      <Oscilloscope client:visible />
    </div>

    <div class="hero__inner wrap">
      <div class="hero__meta" aria-hidden="true">
        <span class="dot dot--tx"></span><span class="lbl">tx</span>
        <span class="dot dot--rx"></span><span class="lbl">rx</span>
        <span class="lbl lbl--mute">/dev/tty.usbmodem · 115200 8N1</span>
      </div>

      <p class="eyebrow"><span class="rule"></span> v1.0 · MIT · Linux · macOS · Windows</p>

      <h1 class="display" transition:name="hero-title">
        <span class="display__line">Talk to hardware.</span>
        <span class="display__line"><em>From&nbsp;JavaScript.</em></span>
      </h1>

      <p class="lede">
        A composable serial-port toolkit for Node.js. Open a port, pipe its stream
        through a parser, and ship the result. Native bindings handle the wire;
        mocks let you test without one.
      </p>

      <div class="cta">
        <a class="btn btn--solid" href="https://github.com/riteshrana/serialpilot" rel="noopener">
          Browse the repo
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
            <path d="M5 3h8v8M13 3 3 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/>
          </svg>
        </a>
        <a class="btn btn--ghost" href="#code">Show me the code</a>
        <a class="btn btn--ghost" href="#try">Try it live ↓</a>
      </div>

      <dl class="hero__stats">
        <div><dt>Packages</dt><dd>21</dd></div>
        <div><dt>Parsers</dt><dd>11</dd></div>
        <div><dt>Bindings</dt><dd>C++ · Mock · Rust</dd></div>
        <div><dt>Node</dt><dd>≥&nbsp;20</dd></div>
      </dl>
    </div>
  </section>

  <!-- PARSER TICKER ─────────────────────────────────────────────── -->
  <ParserTicker />

  <!-- FEATURES ─────────────────────────────────────────────────── -->
  <section id="features" class="features wrap section-gap">
    <header class="section-head">
      <p class="kicker">/01 — what you get</p>
      <h2 class="h2">A small core, with the right edges <em>sharpened.</em></h2>
    </header>

    <ul class="grid grid--cards">
      <li><a class="card" href={link('/docs/packages#bindings')}>
        <span class="card__num">01</span>
        <svg class="card__icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        <h3 class="card__h">Cross-platform, native.</h3>
        <p class="card__p">N-API bindings compiled for Linux, macOS and Windows — with prebuilds, so consumers don't need a toolchain. A Rust crate ships alongside.</p>
        <span class="card__cta" aria-hidden="true">Bindings ↗</span>
      </a></li>
      <li><a class="card" href={link('/docs/parsers')}>
        <span class="card__num">02</span>
        <svg class="card__icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12c2-3 4-3 6 0s4 3 6 0 4-3 4 0" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round"/></svg>
        <h3 class="card__h">Eleven parsers, one stream.</h3>
        <p class="card__p">Readline, delimiter, byte-length, regex, packet-length, ccTalk, SLIP, Space Packet — pipe raw bytes into the shape your protocol expects.</p>
        <span class="card__cta" aria-hidden="true">All parsers ↗</span>
      </a></li>
      <li><a class="card" href={link('/docs/recipes/reconnect')}>
        <span class="card__num">03</span>
        <svg class="card__icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 4v8l5 3" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round"/>
          <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.4" fill="none"/>
        </svg>
        <h3 class="card__h">Built for the messy world.</h3>
        <p class="card__p">Auto-reconnect for flaky USB cables. A request/response queue for AT commands, Modbus RTU, ccTalk. Strongly-typed errors throughout.</p>
        <span class="card__cta" aria-hidden="true">Reconnect recipe ↗</span>
      </a></li>
      <li><a class="card" href={link('/docs/cli')}>
        <span class="card__num">04</span>
        <svg class="card__icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 5h16v14H4z" stroke="currentColor" stroke-width="1.4" fill="none"/>
          <path d="M7 9l3 3-3 3M12 15h5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round"/>
        </svg>
        <h3 class="card__h">Tools, not just APIs.</h3>
        <p class="card__p"><code>serialpilot-list</code>, <code>serialpilot-terminal</code>, and <code>serialpilot-repl</code> ship as binaries. Discover ports, talk to them, script against them.</p>
        <span class="card__cta" aria-hidden="true">CLI tools ↗</span>
      </a></li>
    </ul>
  </section>

  <!-- CODE ─────────────────────────────────────────────────────── -->
  <section id="code" class="code wrap section-gap">
    <header class="section-head">
      <p class="kicker">/02 — first contact</p>
      <h2 class="h2">From <code>npm install</code> to first byte.</h2>
    </header>

    <CodeTabs
      tabs={[
        { id: 'install', label: 'Install',       raw: installRaw, html: installHtml },
        { id: 'open',    label: 'Open a port',   raw: openRaw,    html: openHtml },
        { id: 'mock',    label: 'Mock for tests', raw: mockRaw,   html: mockHtml },
      ]}
    />

    <p class="codecard__note">
      Three commands away from a working integration test. The same parsers work
      against the mock and against real silicon.
    </p>
  </section>

  <!-- WEBSERIAL DEMO ────────────────────────────────────────────── -->
  <section id="try" class="try wrap section-gap">
    <header class="section-head">
      <p class="kicker">/03 — try it live</p>
      <h2 class="h2">Plug something in. <em>This page</em> can read it.</h2>
    </header>
    <p class="lede" style="margin-bottom: var(--s-5); max-width: 60ch;">
      WebSerial lets the browser open a USB-CDC port directly. Connect an
      Arduino, an FTDI cable, or any serial device — frames stream straight into
      the console below. Don't have hardware handy?
      <em>Run the mock</em> instead — same parser pipeline, no wire.
    </p>
    <WebSerialDemo client:idle />
  </section>

  <!-- PACKAGES ─────────────────────────────────────────────────── -->
  <section id="packages" class="packages wrap section-gap">
    <header class="section-head">
      <p class="kicker">/04 — the matrix</p>
      <h2 class="h2">Twenty-one packages. <em>Take what you need.</em></h2>
    </header>
    <PackageMatrix />
  </section>

  <!-- DEPLOYMENT ROSTER ─────────────────────────────────────────── -->
  <section id="field" class="field wrap section-gap">
    <header class="section-head">
      <p class="kicker">/05 — deployment roster</p>
      <h2 class="h2">One toolkit. <em>A thousand wires.</em></h2>
    </header>

    <ol class="field__roster">
      <li class="dossier">
        <header class="dossier__head">
          <span class="dossier__id">R/01</span>
          <span class="dossier__class">Robotics</span>
          <span class="dossier__rule" aria-hidden="true"></span>
          <span class="dossier__locale">bench → sky</span>
        </header>
        <h3 class="dossier__h">Powers NodeBots.</h3>
        <p class="dossier__p">
          The bridge between your JavaScript and the firmware on
          <em>thousands of devices</em> — from an Arduino on the bench to a swarm
          of drones overhead. Same stream, same parsers, same shape.
        </p>
        <ul class="dossier__tags" aria-label="Frameworks">
          <li>firmata</li><li>johnny-five</li><li>arduino</li><li>raspberry-pi</li><li>drones</li>
        </ul>
      </li>

      <li class="dossier">
        <header class="dossier__head">
          <span class="dossier__id">R/02</span>
          <span class="dossier__class">Consumer</span>
          <span class="dossier__rule" aria-hidden="true"></span>
          <span class="dossier__locale">counter → cartridge</span>
        </header>
        <h3 class="dossier__h">From kitchen counters to game cartridges.</h3>
        <p class="dossier__p">
          Pancake-printing arms. Hallway IoT widgets. Homebrew handhelds. Pair with
          Electron and the road from breadboard to shipped app stays
          <em>one Node process wide.</em>
        </p>
        <ul class="dossier__tags" aria-label="Stacks">
          <li>electron</li><li>iot</li><li>hobby</li><li>homebrew</li><li>maker</li>
        </ul>
      </li>

      <li class="dossier">
        <header class="dossier__head">
          <span class="dossier__id">R/03</span>
          <span class="dossier__class">Commercial</span>
          <span class="dossier__rule" aria-hidden="true"></span>
          <span class="dossier__locale">subsea → ICU</span>
        </header>
        <h3 class="dossier__h">Underwater, underground, <em>under audit.</em></h3>
        <p class="dossier__p">
          Subsea sensors. Cargo drones. ATMs at three a.m. Forklift telematics.
          Bedside monitors. SerialPilot wears its MIT licence into rooms that
          don't usually let open source in — and patches flow back.
        </p>
        <ul class="dossier__tags" aria-label="Industries">
          <li>maritime</li><li>aerospace</li><li>fintech</li><li>industrial</li><li>medical</li>
        </ul>
      </li>
    </ol>

    <aside class="field__strip" aria-label="At a glance">
      <span class="field__strip-lbl">// trusted</span>
      <span class="field__strip-stat"><strong>100,000+</strong> developers</span>
      <span class="field__strip-sep" aria-hidden="true"></span>
      <span class="field__strip-stat">Hobby benches → <em>production lines</em></span>
      <span class="field__strip-sep" aria-hidden="true"></span>
      <span class="field__strip-stat">Same three lines of code</span>
    </aside>
  </section>

  <!-- END CTA ──────────────────────────────────────────────────── -->
  <section class="endcta">
    <div class="endcta__grid" aria-hidden="true"></div>
    <div class="wrap endcta__inner">
      <h2 class="endcta__h">Plug something in.<br><em>See what it says.</em></h2>
      <div class="cta">
        <a class="btn btn--solid btn--inv" href="https://github.com/riteshrana/serialpilot" rel="noopener">Open the repo</a>
        <a class="btn btn--ghost btn--inv" href={link('/docs')}>Read the docs</a>
      </div>
      <p class="endcta__tip">
        SerialPilot is built &amp; maintained by one person. If it saves you a weekend,
        <a href="https://buymeacoffee.com/ritesh.rana" rel="noopener">buy me a coffee&nbsp;☕</a>
      </p>
    </div>
  </section>

</MarketingLayout>
